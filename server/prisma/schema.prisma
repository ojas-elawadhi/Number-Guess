generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlayerProgress {
  playerKey         String   @id
  displayName       String
  profile           Json
  totalPoints       Int      @default(0)
  level             Int      @default(1)
  currentWinStreak  Int      @default(0)
  onlinePoints      Int      @default(0)
  onlineWins        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([onlinePoints(sort: Desc), level(sort: Desc)])
  @@index([totalPoints(sort: Desc), level(sort: Desc)])
}

model DailyPuzzle {
  dateKey      String   @id
  secretNumber Int
  maxNumber    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
