generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlayerProgress {
  playerKey         String   @id
  displayName       String
  profile           Json
  totalPoints       Int      @default(0)
  level             Int      @default(1)
  currentWinStreak  Int      @default(0)
  onlinePoints      Int      @default(0)
  onlineWins        Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([onlinePoints(sort: Desc), level(sort: Desc)])
  @@index([totalPoints(sort: Desc), level(sort: Desc)])
}

model DailyPuzzle {
  dateKey      String   @id
  secretNumber Int
  maxNumber    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailyPuzzleResult {
  id                  String    @id @default(cuid())
  dateKey             String
  playerKey           String
  displayNameSnapshot String
  avatarIdSnapshot    String    @default("scholar")
  attempts            Int
  durationMs          Int
  completedAt         DateTime
  rewardEligible      Boolean   @default(true)
  rewardCoinsAwarded  Int       @default(0)
  rewardAwardedAt     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([dateKey, playerKey])
  @@index([dateKey, attempts, durationMs, completedAt])
  @@index([dateKey, rewardEligible, attempts, durationMs])
  @@index([playerKey, dateKey])
}
