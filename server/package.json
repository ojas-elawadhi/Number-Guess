{
  "name": "higher-lower-server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server/src/index.js",
  "scripts": {
    "dev": "tsx watch --include ../shared/**/*.ts src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "prisma": "^6.18.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
