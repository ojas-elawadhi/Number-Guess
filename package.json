{
  "name": "higher-lower-multiplayer",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "server": "npm --prefix server run dev",
    "server:build": "npm --prefix server run build",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "npm --prefix server run typecheck",
    "dev": "concurrently \"npm run server\" \"npm run start\""
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^10.2.2",
    "react-native-purchases-ui": "^10.2.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
